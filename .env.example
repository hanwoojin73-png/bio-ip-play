# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon (public) key: Supabase Dashboard → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# Service role key (server-side only, never expose to the browser):
# Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxx

# ── Blockchain ────────────────────────────────────────────────────────────────
# BioIPRegistry contract deployed on Polygon Amoy (chainId 80002)
# Set to the zero address for mock mode
NEXT_PUBLIC_BIO_IP_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: override the Amoy RPC endpoint (defaults to the public one)
# NEXT_PUBLIC_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# ── Mock mode ─────────────────────────────────────────────────────────────────
# true  → bypass MetaMask / real transactions; generates a fake tx hash + 2s delay
#         Supabase licenses table is still written (real DB, fake hash)
# false → real Polygon Amoy transactions (requires MetaMask + MATIC)
NEXT_PUBLIC_MOCK_BLOCKCHAIN=true

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change_me_before_deploying
